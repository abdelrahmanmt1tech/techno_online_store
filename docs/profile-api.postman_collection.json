{
  "info": {
    "name": "Techno Online Store - Profile API",
    "description": "User profile API for tenant store customers.\n\nBase URL: {{tenant_url}}/api\n\nSet `tenant_url` to the tenant subdomain, e.g. `https://store1.example.com`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "tenant_url",
      "value": "http://store1.localhost",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{tenant_url}}/api/profile",
              "host": ["{{tenant_url}}"],
              "path": ["api", "profile"]
            },
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "description": "Get the authenticated user's profile."
          },
          "response": [
            {
              "name": "Success (200)",
              "body": "{\n  \"success\": true,\n  \"message\": \"Data fetched successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"+1234567890\",\n    \"avatar\": \"http://store1.localhost/storage/tenant1/avatars/abc-123.jpg\",\n    \"is_verified\": true,\n    \"created_at\": \"2026-07-22T12:00:00.000000Z\"\n  }\n}"
            },
            {
              "name": "Unauthenticated (401)",
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            }
          ]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{tenant_url}}/api/profile",
              "host": ["{{tenant_url}}"],
              "path": ["api", "profile"]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "John Doe Updated", "type": "text" },
                { "key": "email", "value": "john@example.com", "type": "text" },
                { "key": "phone", "value": "+1234567890", "type": "text" },
                { "key": "avatar", "type": "file", "src": "" }
              ]
            },
            "description": "Update the authenticated user's profile. All fields are optional. Avatar is a file upload (max 2MB, jpg/png/webp)."
          },
          "response": [
            {
              "name": "Success (200)",
              "body": "{\n  \"success\": true,\n  \"message\": \"Profile updated successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"John Doe Updated\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"+1234567890\",\n    \"avatar\": \"http://store1.localhost/storage/tenant1/avatars/new-avatar.jpg\",\n    \"is_verified\": true,\n    \"created_at\": \"2026-07-22T12:00:00.000000Z\"\n  }\n}"
            },
            {
              "name": "Validation Error (422)",
              "body": "{\n  \"message\": \"The email field is already taken.\",\n  \"errors\": {\n    \"email\": [\"The email has already been taken.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{tenant_url}}/api/profile/password",
              "host": ["{{tenant_url}}"],
              "path": ["api", "profile", "password"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"oldpassword123\",\n  \"password\": \"newpassword456\",\n  \"password_confirmation\": \"newpassword456\"\n}"
            },
            "description": "Update the authenticated user's password. Requires current password. New password must be at least 8 characters and confirmed."
          },
          "response": [
            {
              "name": "Success (200)",
              "body": "{\n  \"success\": true,\n  \"message\": \"Password updated successfully.\"\n}"
            },
            {
              "name": "Wrong Current Password (422)",
              "body": "{\n  \"success\": false,\n  \"message\": \"The current password is incorrect.\"\n}"
            },
            {
              "name": "Validation Error (422)",
              "body": "{\n  \"message\": \"The password field must be at least 8 characters.\",\n  \"errors\": {\n    \"password\": [\"The password field must be at least 8 characters.\"]\n  }\n}"
            }
          ]
        }
      ]
    }
  ]
}
