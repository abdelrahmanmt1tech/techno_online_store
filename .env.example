APP_NAME=Laravel
APP_ENV=local
BYPASS_PERMISSIONS=true
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Public legal / Meta App contact (Privacy, Terms, Data Deletion pages)
SUPPORT_EMAIL=support@technowebmasr.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_CONNECTION=sqlite
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Staging may use "sync" (no worker). Production: database or redis + supervisor.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WhatsApp Cloud API
# Meta latest Graph API is v25.0 (Feb 2026). v21.0 still works; bump via env when ready.
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
# Must stay false when META_APP_SECRET is set (staging/production).
WHATSAPP_ALLOW_UNSIGNED_WEBHOOKS=false
WHATSAPP_DEFAULT_LOCALE=ar
WHATSAPP_REQUEST_TIMEOUT=30
WHATSAPP_LOG_CHANNEL=stack
WHATSAPP_WEBHOOK_LOG_CHANNEL=whatsapp-webhook
WHATSAPP_SEND_RATE_LIMIT=30
WHATSAPP_WEBHOOK_PAYLOAD_RETENTION=minimized

# WhatsApp Embedded Signup — central domain only (do not add every tenant subdomain to Meta Allowed Domains)
META_APP_ID=
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=
# Separate Meta Embedded Signup config for WhatsApp Business App coexistence (do not reuse API Only config unless Meta confirms).
WHATSAPP_EMBEDDED_SIGNUP_COEXISTENCE_CONFIG_ID=
WHATSAPP_EMBEDDED_SIGNUP_CENTRAL_DOMAIN=online-store.technomasrsystems.com
# WHATSAPP_EMBEDDED_SIGNUP_ENFORCE_DOMAIN=true
# WHATSAPP_ONBOARDING_STATE_TTL=900
# WHATSAPP_ONBOARDING_SESSION_RETENTION_DAYS=7

# Messenger (Meta Page webhooks) — uses META_APP_SECRET above for X-Hub-Signature-256
# Set MESSENGER_WEBHOOK_VERIFY_TOKEN to match Meta App Dashboard (Messenger callback verify token).
MESSENGER_WEBHOOK_VERIFY_TOKEN=
# Must stay false when META_APP_SECRET is set (staging/production).
MESSENGER_ALLOW_UNSIGNED_WEBHOOKS=false
MESSENGER_GRAPH_API_VERSION=v21.0
MESSENGER_REQUEST_TIMEOUT=30
MESSENGER_LOG_CHANNEL=stack
MESSENGER_WEBHOOK_LOG_CHANNEL=messenger-webhook
MESSENGER_WEBHOOK_LOG_DAYS=14
MESSENGER_WEBHOOK_PAYLOAD_RETENTION=minimized

# Messenger Facebook Login for Business (Phase G) — central domain only
MESSENGER_FACEBOOK_LOGIN_CONFIG_ID=
MESSENGER_OAUTH_REDIRECT_URI="${APP_URL}/messenger/onboarding/callback"
MESSENGER_OAUTH_SCOPES=pages_show_list,pages_manage_metadata,pages_messaging
MESSENGER_ONBOARDING_CENTRAL_DOMAIN=online-store.technomasrsystems.com
# MESSENGER_ONBOARDING_ENFORCE_DOMAIN=true
# MESSENGER_ONBOARDING_STATE_TTL=900
# MESSENGER_PAGE_SUBSCRIBED_FIELDS=messages,messaging_postbacks,message_deliveries,message_reads,messaging_seen
# MESSENGER_ONBOARDING_SESSION_RETENTION_DAYS=7
